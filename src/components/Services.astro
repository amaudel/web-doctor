---
---
<!-- Sección: Servicios y Procedimientos -->
<section class="bg-light-sec" id="servicios">
  <div class="container">
    <div class="section-header" style="margin-bottom: 60px;">
      <span class="section-subtitle">Especialidades</span>
      <h2 class="section-title">Servicios de Cirugía General y Laparoscópica en Cuenca</h2>
    </div>

    <div class="services-grid">
      <!-- Columna: Cirugía Laparoscópica (Featured style) -->
      <div class="services-column featured">
        <h3 class="services-column-title">
          <!-- Star SVG -->
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          Cirugía Laparoscópica (Mínima Invasión)
        </h3>
        
        <div class="service-list">
          <div class="service-card">
            <h4>Colecistectomía Laparoscópica <span class="service-tag">Frecuente</span></h4>
            <p class="service-short-desc">Extracción de la vesícula biliar por presencia de cálculos (piedras) mediante incisiones milimétricas.</p>
            <div class="service-full-desc hidden">
              <p>Ofrece menor dolor postoperatorio, menor cicatriz y rápida alta clínica tras una <strong>cirugía laparoscópica en Cuenca</strong> con tecnología laparoscópica moderna.</p>
            </div>
            <button class="btn-service-more" aria-expanded="false">
              <span>Ver más</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
          <div class="service-card">
            <h4>Hernioplastia Laparoscópica <span class="service-tag">Avanzada</span></h4>
            <p class="service-short-desc">Reparación de hernias inguinales o de la pared abdominal mediante laparoscopía.</p>
            <div class="service-full-desc hidden">
              <p>Incluye la colocación de mallas biocompatibles de alta resistencia para evitar la reaparición y acelerar la recuperación.</p>
            </div>
            <button class="btn-service-more" aria-expanded="false">
              <span>Ver más</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
          <div class="service-card">
            <h4>Apendicectomía Laparoscópica <span class="service-tag">Urgencia</span></h4>
            <p class="service-short-desc">Procedimiento de <strong>cirugía laparoscópica en Cuenca</strong> para extraer el apéndice inflamado.</p>
            <div class="service-full-desc hidden">
              <p>Se realiza de urgencia ante cuadros de apendicitis aguda, previniendo peritonitis y minimizando el tiempo de recuperación.</p>
            </div>
            <button class="btn-service-more" aria-expanded="false">
              <span>Ver más</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Columna: Cirugía Convencional (Standard style) -->
      <div class="services-column standard">
        <h3 class="services-column-title">
          <!-- Activity SVG -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          Cirugía Convencional y Procedimientos
        </h3>
        
        <div class="service-list">
          <div class="service-card">
            <h4>Extirpación de Lipomas y Quistes</h4>
            <p class="service-short-desc">Retiro ambulatorio de lipomas, quistes sebáceos o pequeños tumores de piel bajo anestesia local.</p>
            <div class="service-full-desc hidden">
              <p>Procedimiento rápido y seguro dentro de la práctica de <strong>cirugía general en Cuenca</strong> en una sesión corta.</p>
            </div>
            <button class="btn-service-more" aria-expanded="false">
              <span>Ver más</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
          <div class="service-card">
            <h4>Reparación de Hernia Convencional</h4>
            <p class="service-short-desc">Corrección de hernias umbilicales, epigástricas o inguinales grandes mediante técnica convencional.</p>
            <div class="service-full-desc hidden">
              <p>Ideal según la valoración física, estado general y anatomía específica de cada paciente.</p>
            </div>
            <button class="btn-service-more" aria-expanded="false">
              <span>Ver más</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
          <div class="service-card">
            <h4>Reconstrucción de Pared Abdominal</h4>
            <p class="service-short-desc">Cirugía reparadora de eventraciones (hernias en cicatrices de operaciones antiguas).</p>
            <div class="service-full-desc hidden">
              <p>Restaura la fuerza, estabilidad y función natural de la musculatura del abdomen.</p>
            </div>
            <button class="btn-service-more" aria-expanded="false">
              <span>Ver más</span>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Add interactivity to the "Ver más" buttons on service cards
  document.querySelectorAll('.service-card').forEach(card => {
    const btn = card.querySelector('.btn-service-more');
    const fullDesc = card.querySelector('.service-full-desc');
    
    if (btn && fullDesc) {
      btn.addEventListener('click', () => {
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', (!isExpanded).toString());
        fullDesc.classList.toggle('hidden', isExpanded);
        
        const btnText = btn.querySelector('span');
        if (btnText) {
          btnText.textContent = isExpanded ? 'Ver más' : 'Ver menos';
        }
      });
    }
  });
</script>
