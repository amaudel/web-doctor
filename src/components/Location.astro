---
---
<!-- Sección: Ubicación y Contacto -->
<section id="ubicacion" style="scroll-margin-top: 100px;">
  <div class="container">
    <div class="section-header" style="text-align: center; margin-bottom: 60px;">
      <span class="section-subtitle">Ubicación y Contacto</span>
      <h2 class="section-title">Lugar de atención médica</h2>
      <p class="lead" style="margin-left: auto; margin-right: auto; text-align: center;">Visítenos en las instalaciones médicas del Hospital San Juan de Dios en Cuenca, Ecuador.</p>
    </div>

    <div class="location-grid">
      <!-- Columna Izquierda: Información de contacto en tarjetas premium -->
      <div class="location-details">
        
        <!-- Tarjeta 1: Dirección -->
        <div class="location-card">
          <div class="location-card-icon" aria-hidden="true">
            <!-- MapPin SVG Icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="location-card-content">
            <h3>Consultorio Médico</h3>
            <p>Hospital Clínico San Juan de Dios<br />Manuel J. Calle 1-59 y Av. Paucarbamba<br />Cuenca, Ecuador</p>
          </div>
        </div>

        <!-- Tarjeta 2: Teléfonos y Citas -->
        <div class="location-card">
          <div class="location-card-icon" aria-hidden="true">
            <!-- Phone SVG Icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div class="location-card-content">
            <h3>Teléfonos y Citas</h3>
            <p>Llamadas consultorio: <a href="tel:+593724125046"><strong>(07) 412-5046</strong></a><br />
            Celular para citas (WhatsApp): <a href="tel:+593982757711"><strong>098 275 7711</strong></a></p>
          </div>
        </div>

        <!-- Tarjeta 3: Horarios de Consulta -->
        <div class="location-card">
          <div class="location-card-icon" aria-hidden="true">
            <!-- Clock SVG Icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="location-card-content">
            <h3>Horarios de Consulta</h3>
            <p>Lunes a Viernes: Previa Cita coordinada por teléfono o WhatsApp.</p>
          </div>
        </div>

        <!-- Tarjeta 4: Respaldo y Confianza (Highlight) -->
        <div class="location-card highlight">
          <div class="location-card-icon" aria-hidden="true">
            <!-- ShieldCheck SVG Icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="location-card-content">
            <h3>Hospital Seguro y Accesible</h3>
            <p>• Atención en el prestigioso Hospital San Juan de Dios<br />• Parqueadero privado vigilado para su vehículo<br />• Seguridad física 24/7 en todas las instalaciones</p>
          </div>
        </div>

        <!-- Botones de Acción (CTAs principales) -->
        <div class="location-ctas">
          <a class="btn btn-accent" href="https://wa.me/593982757711?text=Hola%20Dr.%20Vintimilla,%20deseo%20agendar%20una%20consulta%20de%20valoración." target="_blank" rel="noopener" aria-label="Agendar consulta con el Dr. Vintimilla por WhatsApp">
            <!-- WhatsApp SVG Icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white" style="margin-right: 4px;"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.488 1.459 5.416 1.46h.007c5.811 0 10.536-4.729 10.54-10.544.003-2.817-1.092-5.466-3.08-7.456C17.48 2.624 14.835 1.528 12.01 1.528c-5.817 0-10.543 4.731-10.548 10.547-.001 1.933.504 3.824 1.464 5.433l-.962 3.513 3.606-.945zm11.388-7.794c-.308-.154-1.82-.9-2.102-1.002-.283-.103-.488-.154-.693.154-.206.308-.797 1.002-.977 1.207-.18.206-.36.231-.668.077-.308-.154-1.3-.48-2.477-1.53-1.155-1.03-1.936-2.302-2.162-2.61-.226-.308-.024-.475.13-.628.138-.138.308-.36.462-.54.154-.18.206-.308.308-.514.103-.206.051-.385-.026-.54-.077-.154-.693-1.67-.95-2.29-.25-.6-.524-.52-.72-.53-.188-.01-.403-.01-.617-.01-.214 0-.564.08-.86.402-.296.322-1.13 1.102-1.13 2.69 0 1.587 1.156 3.12 1.316 3.326.16.206 2.274 3.473 5.508 4.872.77.332 1.37.531 1.838.68.775.246 1.48.212 2.037.129.62-.093 1.82-.745 2.078-1.464.256-.718.256-1.334.18-1.463-.077-.13-.283-.206-.59-.36z"/></svg>
            Agendar por WhatsApp
          </a>
          <a class="btn btn-secondary-outline" href="tel:+593724125046" aria-label="Llamar al consultorio del Dr. Vintimilla por teléfono">
            <!-- Phone SVG Icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Llamar al Consultorio
          </a>
        </div>
      </div>

      <!-- Columna Derecha: Mapa y acciones de llegada -->
      <div class="location-map-wrapper">
        <div class="map-container">
          <!-- Google Maps Iframe Real con lazy loading y título accesible -->
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3984.697486043961!2d-79.00685652515093!3d-2.903822139626383!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91cd19b027b40d6d%3A0x6d8593ccf9a46320!2sHospital%20San%20Juan%20de%20Dios!5e0!3m2!1ses!2sec!4v1718376543210!5m2!1ses!2sec" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Mapa interactivo de ubicación del Hospital San Juan de Dios en Cuenca, Ecuador"></iframe>
        </div>

        <!-- Tarjeta de Cómo llegar (Google Maps y Waze) -->
        <div class="navigation-actions">
          <span class="navigation-label">¿Cómo llegar al consultorio?</span>
          <div class="navigation-buttons">
            <a class="btn btn-sm btn-secondary" href="https://www.google.com/maps/dir/?api=1&destination=Hospital+Cl%C3%ADnico+San+Juan+de+Dios,+Cuenca" target="_blank" rel="noopener" aria-label="Iniciar ruta de navegación hacia el consultorio en Google Maps">
              <!-- Navigation Arrow SVG -->
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
              Iniciar Ruta (Google Maps)
            </a>
            <a class="btn btn-sm btn-secondary-outline" href="https://waze.com/ul?ll=-2.903822,-79.006856&navigate=yes" target="_blank" rel="noopener" style="border-color: var(--border);" aria-label="Iniciar ruta de navegación hacia el consultorio en Waze">
              <!-- Navigation Compass/Map Icon -->
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
              Iniciar Ruta (Waze)
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
