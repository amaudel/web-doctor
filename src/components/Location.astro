---
---
<!-- Sección: Ubicación y Contacto -->
<section id="ubicacion">
  <div class="container location-grid">
    <div class="location-info">
      <span class="section-subtitle">Contacto</span>
      <h2 class="section-title" style="margin-bottom: 24px;">Lugar de atención médica</h2>
      <p class="lead" style="font-size: 1rem; margin-bottom: 32px;">Visítenos en las instalaciones médicas del Hospital San Juan de Dios en Cuenca, Ecuador. Contamos con parqueadero privado y seguridad.</p>
      
      <div class="contact-item">
        <div class="contact-icon">
          <!-- MapPin SVG -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div class="contact-detail">
          <h4>Consultorio Médico</h4>
          <p>Hospital Clínico San Juan de Dios<br />Manuel J. Calle 1-59 y Av. Paucarbamba<br />Cuenca, Ecuador</p>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-icon">
          <!-- Phone SVG -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="contact-detail">
          <h4>Números de Teléfono</h4>
          <p>Llamadas consultorio: <a href="tel:+593724125046"><strong>(07) 412-5046</strong></a><br />
          Celular para citas: <a href="tel:+593982757711"><strong>098 275 7711</strong></a></p>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-icon">
          <!-- Clock SVG -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="contact-detail">
          <h4>Horarios de Consulta</h4>
          <p>Lunes a Viernes: Previa Cita coordinada por teléfono o WhatsApp.</p>
        </div>
      </div>

      <div class="location-actions">
        <a class="btn btn-primary" href="tel:+593724125046">Llamar Ahora</a>
        <a class="btn btn-secondary-outline" href="https://wa.me/593982757711?text=Hola%20Dr.%20Vintimilla,%20deseo%20agendar%20una%20consulta%20de%20valoración." target="_blank" rel="noopener">Agendar por WhatsApp</a>
      </div>

      <div class="navigation-actions" style="margin-top: 24px; border-top: 1px solid var(--border-light); padding-top: 24px;">
        <h4 style="font-family: 'Outfit', sans-serif; font-size: 1rem; color: var(--primary-dark); margin-bottom: 14px; font-weight: 700;">¿Cómo llegar al consultorio?</h4>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <a class="btn btn-sm btn-secondary" href="https://www.google.com/maps/dir/?api=1&destination=Hospital+Cl%C3%ADnico+San+Juan+de+Dios,+Cuenca" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px;">
            <!-- Navigation Arrow SVG -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
            Iniciar Ruta (Google Maps)
          </a>
          <a class="btn btn-sm btn-secondary-outline" href="https://waze.com/ul?ll=-2.903822,-79.006856&navigate=yes" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px;">
            <!-- Navigation Car SVG -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2" ry="2"/><line x1="16" y1="8" x2="20" y2="8"/><line x1="16" y1="12" x2="23" y2="12"/><line x1="18" y1="8" x2="21" y2="12"/></svg>
            Iniciar Ruta (Waze)
          </a>
        </div>
      </div>
    </div>

    <div class="map-container">
      <!-- Google Maps Iframe Real -->
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3984.697486043961!2d-79.00685652515093!3d-2.903822139626383!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91cd19b027b40d6d%3A0x6d8593ccf9a46320!2sHospital%20San%20Juan%20de%20Dios!5e0!3m2!1ses!2sec!4v1718376543210!5m2!1ses!2sec" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Ubicación Hospital Clínico San Juan de Dios en Google Maps"></iframe>
    </div>
  </div>
</section>
