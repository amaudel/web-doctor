---
import { Image, getImage } from 'astro:assets';
import hospitalBg from '../assets/hospital_bg.jpg';
import doctorPortrait from '../assets/doctor_portrait.jpg';

// Optimizar la imagen de fondo en formato webp con Astro Assets
const optimizedBg = await getImage({
  src: hospitalBg,
  format: 'webp',
  width: 1920,
  height: 1080,
  quality: 85
});
---
<!-- Hero Section / Introducción -->
<section class="hero" id="inicio">
  <!-- Optimized background image container -->
  <div class="hero-bg" style={`background-image: url('${optimizedBg.src}');`} aria-hidden="true"></div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="container hero-grid">
    <div class="hero-content">
      <span class="eyebrow">
        <!-- Stethoscope SVG Icon -->
        <svg viewBox="0 0 24 24"><path d="M19 8c-.55 0-1 .45-1 1v3c0 2.21-1.79 4-4 4s-4-1.79-4-4V9c0-1.66-1.34-3-3-3S4 7.34 4 9v3c0 3.39 2.42 6.21 5.61 6.8-.46.74-.61 1.63-.4 2.5C9.69 22.84 11.23 24 13 24c2.21 0 4-1.79 4-4v-1.1c2.83-.93 5-3.59 5-6.9V9c0-.55-.45-1-1-1zm-9 4c0-1.1.9-2 2-2s2 .9 2 2-.9 2-2 2-2-.9-2-2zM6 9c0-.55.45-1 1-1s1 .45 1 1v3c0 1.1-.9 2-2 2s-2-.9-2-2V9zm7 13c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/></svg>
        Atención Quirúrgica en Cuenca
      </span>
      <h1 class="hero-title">
        <span class="text-white">DR. RAÚL VINTIMILLA</span>
        <span class="text-cyan">Cirujano General y Laparoscopista</span>
      </h1>
      <p class="lead">Cirujano con amplia trayectoria en Cuenca. El Dr. Raúl Vintimilla Ávila le ofrece una evaluación honesta y profesional, enfocada en su seguridad y recuperación ágil.</p>
      
      <div class="hero-actions">
        <a class="btn btn-accent" href="https://wa.me/593982757711?text=Hola%20Dr.%20Vintimilla,%20deseo%20agendar%20una%20consulta%20de%20valoración." target="_blank" rel="noopener">
          <!-- WhatsApp SVG Icon -->
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.488 1.459 5.416 1.46h.007c5.811 0 10.536-4.729 10.54-10.544.003-2.817-1.092-5.466-3.08-7.456C17.48 2.624 14.835 1.528 12.01 1.528c-5.817 0-10.543 4.731-10.548 10.547-.001 1.933.504 3.824 1.464 5.433l-.962 3.513 3.606-.945zm11.388-7.794c-.308-.154-1.82-.9-2.102-1.002-.283-.103-.488-.154-.693.154-.206.308-.797 1.002-.977 1.207-.18.206-.36.231-.668.077-.308-.154-1.3-.48-2.477-1.53-1.155-1.03-1.936-2.302-2.162-2.61-.226-.308-.024-.475.13-.628.138-.138.308-.36.462-.54.154-.18.206-.308.308-.514.103-.206.051-.385-.026-.54-.077-.154-.693-1.67-.95-2.29-.25-.6-.524-.52-.72-.53-.188-.01-.403-.01-.617-.01-.214 0-.564.08-.86.402-.296.322-1.13 1.102-1.13 2.69 0 1.587 1.156 3.12 1.316 3.326.16.206 2.274 3.473 5.508 4.872.77.332 1.37.531 1.838.68.775.246 1.48.212 2.037.129.62-.093 1.82-.745 2.078-1.464.256-.718.256-1.334.18-1.463-.077-.13-.283-.206-.59-.36z"/></svg>
          Agendar Cita por WhatsApp
        </a>
        <a class="btn btn-secondary-outline hero-phone-btn" href="tel:+593724125046">
          <!-- Phone SVG Icon -->
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Llamar al Consultorio
        </a>
      </div>

      <div class="badges">
        <div class="badge">
          <strong>+30 Años</strong>
          <span>Trayectoria médica</span>
        </div>
        <div class="badge">
          <strong>Mínima Invasión</strong>
          <span>Cirugía Laparoscópica</span>
        </div>
        <div class="badge">
          <strong>Socio Fundador</strong>
          <span>Hospital San Juan de Dios</span>
        </div>
      </div>
    </div>
    
    <div class="hero-card">
      <div class="hero-img-container">
        <Image src={doctorPortrait} alt="Dr. Raúl Vintimilla Ávila, cirujano general en Cuenca y cirujano laparoscopista en Cuenca" width={400} height={500} loading="eager" decoding="async" format="webp" />
      </div>
      <div class="hero-card-tag">
        <div class="hero-card-tag-icon">
          <!-- Shield Check SVG -->
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
        </div>
        <div class="hero-card-tag-text">
          <strong>Práctica Médica Ética</strong>
          <span>Seguridad en cada cirugía</span>
        </div>
      </div>
    </div>
  </div>
</section>
