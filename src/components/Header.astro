---
<!-- Cabecera de Navegación -->
<header class="header">
  <div class="container nav">
    <a href="/#inicio" class="brand" aria-label="Inicio Dr. Raúl Vintimilla Ávila">
      <span class="brand-name">Dr. Raúl Vintimilla Á.</span>
      <span class="brand-sub">Cirujano General y Laparoscopista</span>
    </a>
    
    <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú de navegación" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="menu" id="navMenu">
      <a href="/#inicio">Inicio</a>
      <a href="/#sintomas">Cuándo Consultar</a>
      <a href="/#perfil">Trayectoria</a>
      <a href="/#servicios">Servicios</a>
      <a href="/#proceso">Proceso</a>
      <a href="/#recursos">Consejos y Recursos</a>
      <a href="/#faq">Preguntas Frecuentes</a>
      <a href="/#ubicacion">Ubicación</a>
      <a href="https://wa.me/593982757711?text=Hola%20Dr.%20Vintimilla,%20deseo%20agendar%20una%20consulta%20de%20valoración." class="menu-cta" target="_blank" rel="noopener">Agendar Cita por WhatsApp</a>
    </nav>

    <div class="nav-actions">
      <a class="btn btn-sm btn-primary" href="tel:+593724125046">Llamar Consultorio</a>
    </div>
  </div>
</header>

<script>
  // Optimizar navegación en la página de inicio convirtiendo "/#anchor" en "#anchor"
  if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
    document.querySelectorAll('a[href^="/#"]').forEach(link => {
      const href = link.getAttribute('href');
      if (href) {
        link.setAttribute('href', href.substring(1));
      }
    });
  }

  // Lógica del menú móvil (Hamburguesa)
  const menuToggle = document.getElementById('menuToggle');
  const navMenu = document.getElementById('navMenu');

  if (menuToggle && navMenu) {
    menuToggle.addEventListener('click', () => {
      const isOpen = navMenu.classList.toggle('open');
      menuToggle.classList.toggle('open', isOpen);
      menuToggle.setAttribute('aria-expanded', isOpen.toString());
      
      if (isOpen) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
    });

    // Cerrar menú al hacer clic en un enlace (móvil)
    const navLinks = navMenu.querySelectorAll('a');
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (navMenu.classList.contains('open')) {
          navMenu.classList.remove('open');
          menuToggle.classList.remove('open');
          menuToggle.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        }
      });
    });

    // Cerrar menú al presionar Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && navMenu.classList.contains('open')) {
        navMenu.classList.remove('open');
        menuToggle.classList.remove('open');
        menuToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    });
  }
</script>
