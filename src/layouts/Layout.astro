---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  isBlogPost?: boolean;
  ogImage?: string;
}

const SITE_URL = "https://web-doctor-orpin.vercel.app";

const {
  title = "Dr. Raúl Marcelo Vintimilla Ávila | Cirujano General y Laparoscopista en Cuenca",
  description = "Agenda una valoración con el Dr. Raúl Marcelo Vintimilla Ávila, cirujano general y laparoscopista en Cuenca. Especialista en cirugía de vesícula, hernias y apéndice en el Hospital San Juan de Dios.",
  canonicalPath = "",
  isBlogPost = false,
  ogImage = "/doctor_portrait.jpg",
} = Astro.props;

const canonicalUrl = `${SITE_URL}${canonicalPath}`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <script is:inline>
    // Detectar si las animaciones están soportadas y no reducidas
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('js-animations');
      
      // Fallback de seguridad: Si en 2.5 segundos no se ha iniciado la animación,
      // se remueve la clase js-animations para asegurar que el contenido sea visible.
      setTimeout(() => {
        if (!document.documentElement.classList.contains('js-animations-started')) {
          document.documentElement.classList.remove('js-animations');
          console.warn('GSAP fallback triggered: hero elements forced visible.');
        }
      }, 2500);
    }
  </script>

  
  <!-- SEO Local Optimizado -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="cirujano general en Cuenca, cirujano laparoscopista en Cuenca, cirugía general en Cuenca, cirugía laparoscópica en Cuenca, vesícula biliar Cuenca, operación de hernias Cuenca, apendicitis Cuenca, Dr. Raul Vintimilla Avila" />
  <link rel="canonical" href={canonicalUrl} />
  
  <!-- Open Graph / Meta Compartir -->
  <meta property="og:type" content={isBlogPost ? "article" : "website"} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${SITE_URL}${ogImage}`} />
  <meta property="og:url" content={canonicalUrl} />

  <!-- Google Fonts: Outfit (Títulos) e Inter (Cuerpo de texto) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">

  <!-- Marcado de Datos Estructurados JSON-LD (SEO Local y Médico) -->
  {
    !isBlogPost ? (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Physician",
        "name": "Dr. Raúl Marcelo Vintimilla Ávila",
        "image": `${SITE_URL}/doctor_portrait.jpg`,
        "description": "Atención especializada de cirugía general y laparoscópica en Cuenca. Consultas y cirugías planificadas previa cita en el Hospital San Juan de Dios.",
        "alumniOf": {
          "@type": "EducationalOrganization",
          "name": "Universidad de Cuenca"
        },
        "medicalSpecialty": [
          "GeneralSurgery",
          "LaparoscopicSurgery"
        ],
        "telephone": "+593724125046",
        "url": `${SITE_URL}/`,
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Manuel J. Calle 1-59 y Av. Paucarbamba, Hospital San Juan de Dios",
          "addressLocality": "Cuenca",
          "addressRegion": "Azuay",
          "postalCode": "010150",
          "addressCountry": "EC"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -2.903822,
          "longitude": -79.006856
        },
        "hospitalAffiliation": {
          "@type": "MedicalOrganization",
          "name": "Hospital San Juan de Dios (Cuenca)",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Manuel J. Calle 1-59 y Av. Paucarbamba",
            "addressLocality": "Cuenca",
            "addressCountry": "EC"
          }
        },
        "knowsAbout": [
          "Colecistectomía laparoscópica",
          "Reparación de hernias",
          "Apendicectomía",
          "Cirugía de tejidos blandos y lipomas"
        ]
      })} />
    ) : null
  }

  {
    isBlogPost ? (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MedicalWebPage",
        "name": title,
        "description": description,
        "url": canonicalUrl,
        "author": {
          "@type": "Person",
          "name": "Dr. Raúl Marcelo Vintimilla Ávila",
          "jobTitle": "Cirujano General y Laparoscopista",
          "worksFor": {
            "@type": "MedicalOrganization",
            "name": "Hospital San Juan de Dios"
          }
        },
        "mainEntityOfPage": canonicalUrl,
        "inLanguage": "es"
      })} />
    ) : null
  }
</head>
<body>
  <!-- Marca de agua médica decorativa de fondo (GSAP) -->
  <div class="medical-watermark" aria-hidden="true">
    <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M50,10 L50,90" />
      <circle cx="50" cy="8" r="2" fill="currentColor" />
      <path d="M50,82 C62,75 62,68 50,61 C38,54 38,47 50,40 C62,33 62,26 50,19 C45,17 44,21 48,23 C50,24 53,22 51,20" />
    </svg>
  </div>

  <slot />
</body>
</html>
