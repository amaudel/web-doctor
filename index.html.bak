<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- SEO Local Optimizado -->
  <title>Dr. Raúl Marcelo Vintimilla Ávila | Cirujano General y Laparoscopista en Cuenca</title>
  <meta name="description" content="Agenda una valoración con el Dr. Raúl Marcelo Vintimilla Ávila, cirujano general y laparoscopista en Cuenca. Especialista en cirugía de vesícula, hernias y apéndice en el Hospital San Juan de Dios." />
  <meta name="keywords" content="cirujano general en Cuenca, cirujano laparoscopista en Cuenca, cirugía general en Cuenca, cirugía laparoscópica en Cuenca, vesícula biliar Cuenca, operación de hernias Cuenca, apendicitis Cuenca, Dr. Raul Vintimilla Avila" />
  <link rel="canonical" href="https://dr-vintimilla-landing.vercel.app/" />
  
  <!-- Open Graph / Meta Compartir -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Dr. Raúl Marcelo Vintimilla Ávila | Cirujano General y Laparoscopista en Cuenca" />
  <meta property="og:description" content="Cirugía general y laparoscópica con trato humano en Cuenca. Especialista en vesícula, hernias y apéndice por laparoscopía en el Hospital San Juan de Dios." />
  <meta property="og:image" content="https://dr-vintimilla-landing.vercel.app/doctor_portrait.png" />
  <meta property="og:url" content="https://dr-vintimilla-landing.vercel.app/" />

  <!-- Google Fonts: Outfit (Títulos) e Inter (Cuerpo de texto) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      /* Paleta de colores clínica y premium */
      --primary-dark: #0f172a;    /* Slate 900 */
      --primary: #0284c7;         /* Sky 600 */
      --primary-hover: #0369a1;   /* Sky 700 */
      --primary-light: #f0f9ff;   /* Sky 50 */
      --accent: #10b981;          /* Emerald 500 */
      --accent-hover: #059669;    /* Emerald 600 */
      --accent-light: #ecfdf5;    /* Emerald 50 */
      
      --text-dark: #1e293b;       /* Slate 800 */
      --text-muted: #64748b;      /* Slate 500 */
      --bg-light: #f8fafc;        /* Slate 50 */
      --bg-card: #ffffff;
      --border: #e2e8f0;          /* Slate 200 */
      --border-light: #f1f5f9;    /* Slate 100 */
      
      /* Sombras premium suavizadas y difusas */
      --shadow-sm: 0 2px 8px rgba(15, 23, 42, 0.03);
      --shadow-md: 0 8px 20px rgba(15, 23, 42, 0.04);
      --shadow-lg: 0 16px 36px rgba(15, 23, 42, 0.06);
      --shadow-premium: 0 24px 64px rgba(15, 23, 42, 0.08);
      
      /* Radio de bordes y transiciones */
      --radius-sm: 12px;
      --radius-md: 18px;
      --radius-lg: 30px;
      --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      
      --max-width: 1200px;
    }

    /* Reset global y accesibilidad */
    * { 
      box-sizing: border-box; 
      margin: 0; 
      padding: 0; 
    }
    
    html { 
      scroll-behavior: smooth; 
      scroll-padding-top: 90px; 
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      color: var(--text-dark);
      background-color: var(--bg-light);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    a { 
      color: inherit; 
      text-decoration: none; 
      transition: var(--transition-smooth);
    }
    
    button {
      font-family: inherit;
    }

    .container { 
      width: min(var(--max-width), calc(100% - 48px)); 
      margin: 0 auto; 
    }

    /* Header y Navegación */
    .header {
      position: sticky; 
      top: 0; 
      z-index: 100;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      background: rgba(255, 255, 255, 0.85);
      border-bottom: 1px solid rgba(226, 232, 240, 0.8);
      box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
      transition: var(--transition-smooth);
    }

    .nav {
      display: flex; 
      align-items: center; 
      justify-content: space-between;
      min-height: 80px; 
      gap: 24px;
    }

    .brand { 
      display: flex;
      flex-direction: column;
    }
    
    .brand-name {
      font-family: 'Outfit', sans-serif;
      font-weight: 800; 
      font-size: 1.3rem;
      line-height: 1.1; 
      color: var(--primary-dark);
      letter-spacing: -0.01em;
    }
    
    .brand-sub { 
      color: var(--primary); 
      font-weight: 700; 
      font-size: 0.82rem; 
      margin-top: 4px; 
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .menu { 
      display: flex; 
      gap: 32px; 
      align-items: center; 
    }
    
    .menu a { 
      color: var(--text-muted); 
      font-weight: 600; 
      font-size: 0.92rem;
      position: relative;
      padding: 6px 0;
    }

    .menu a:hover {
      color: var(--primary);
    }

    .menu a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background-color: var(--primary);
      transition: var(--transition-smooth);
    }

    .menu a:hover::after {
      width: 100%;
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    /* Botones */
    .btn {
      display: inline-flex; 
      align-items: center; 
      justify-content: center;
      gap: 10px; 
      padding: 14px 28px; 
      border-radius: var(--radius-sm); 
      border: none;
      font-weight: 700; 
      font-size: 0.95rem;
      cursor: pointer; 
      transition: var(--transition-smooth); 
    }

    .btn-sm {
      padding: 10px 20px;
      font-size: 0.88rem;
    }

    .btn-primary { 
      background: var(--primary); 
      color: white; 
    }
    
    .btn-primary:hover { 
      background: var(--primary-hover); 
      transform: translateY(-2px); 
      box-shadow: 0 8px 20px rgba(2, 132, 199, 0.25);
    }

    .btn-secondary-outline { 
      background: transparent; 
      color: var(--primary); 
      border: 2px solid rgba(2, 132, 199, 0.3); 
    }
    
    .btn-secondary-outline:hover { 
      background: var(--primary-light);
      border-color: var(--primary);
      transform: translateY(-2px); 
    }

    .btn-secondary {
      background: var(--primary-light);
      color: var(--primary-hover);
      border: 1px solid rgba(2, 132, 199, 0.15);
    }
    
    .btn-secondary:hover {
      background: rgba(2, 132, 199, 0.10);
      transform: translateY(-2px);
    }

    .btn-accent {
      background: var(--accent);
      color: white;
    }

    .btn-accent:hover {
      background: var(--accent-hover);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(16, 185, 129, 0.25);
    }

    /* Menu móvil (Hamburguesa) */
    .menu-toggle {
      display: none;
      flex-direction: column;
      justify-content: space-between;
      width: 24px;
      height: 18px;
      background: transparent;
      border: none;
      cursor: pointer;
      z-index: 101;
    }

    .menu-toggle span {
      display: block;
      width: 100%;
      height: 2px;
      background-color: var(--primary-dark);
      border-radius: 2px;
      transition: var(--transition-smooth);
    }

    /* Hero Section */
    .hero {
      padding: 112px 0 96px;
      background: radial-gradient(circle at 80% 20%, rgba(2, 132, 199, 0.05), transparent 50%),
                  radial-gradient(circle at 20% 80%, rgba(16, 185, 129, 0.03), transparent 50%),
                  linear-gradient(to bottom, #ffffff, #f8fafc);
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(rgba(2, 132, 199, 0.05) 1.5px, transparent 1.5px);
      background-size: 32px 32px;
      pointer-events: none;
    }

    .hero-grid {
      display: grid; 
      grid-template-columns: 1.15fr 0.85fr; 
      gap: 56px; 
      align-items: center;
      position: relative;
      z-index: 2;
    }

    .eyebrow {
      display: inline-flex; 
      align-items: center; 
      gap: 8px;
      padding: 6px 16px; 
      background: rgba(2, 132, 199, 0.05); 
      color: var(--primary-hover);
      border: 1px solid rgba(2, 132, 199, 0.12);
      border-radius: 999px; 
      font-weight: 600; 
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 24px;
    }
    
    .eyebrow svg {
      width: 14px;
      height: 14px;
      fill: currentColor;
    }

    h1 {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(2.4rem, 4.5vw, 3.6rem);
      line-height: 1.12; 
      margin-bottom: 24px;
      color: var(--primary-dark);
      letter-spacing: -0.03em;
      font-weight: 800;
    }

    h1 span {
      color: var(--primary);
      font-size: clamp(1.2rem, 2.2vw, 1.6rem);
      display: block;
      margin-top: 12px;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .lead { 
      font-size: clamp(1.05rem, 1.3vw, 1.18rem); 
      color: var(--text-muted); 
      margin-bottom: 36px;
      max-width: 620px; 
    }

    .hero-actions { 
      display: flex; 
      gap: 16px; 
      flex-wrap: wrap; 
      margin-bottom: 48px; 
    }
    
    .hero-actions .btn {
      padding: 16px 32px;
    }

    .badges {
      display: grid; 
      grid-template-columns: repeat(3, 1fr); 
      gap: 20px; 
    }

    .badge {
      background: var(--bg-card); 
      border: 1px solid rgba(226, 232, 240, 0.8); 
      border-top: 3px solid var(--primary);
      border-radius: var(--radius-sm); 
      padding: 18px 16px;
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: var(--transition-smooth);
    }
    
    .badge:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
      border-color: rgba(2, 132, 199, 0.2);
    }

    .badge strong { 
      display: block; 
      font-family: 'Outfit', sans-serif;
      font-size: 1.35rem; 
      color: var(--primary-dark);
      letter-spacing: -0.01em;
    }
    
    .badge span {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .hero-card {
      position: relative;
      display: flex;
      justify-content: center;
    }

    .hero-card::after {
      content: '';
      position: absolute;
      width: 320px;
      height: 320px;
      background: radial-gradient(circle, rgba(2, 132, 199, 0.12) 0%, transparent 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 1;
      pointer-events: none;
    }

    .hero-img-container {
      width: 100%;
      max-width: 380px;
      aspect-ratio: 4 / 5;
      border-radius: var(--radius-lg);
      background: linear-gradient(135deg, var(--primary-light) 0%, #ffffff 100%);
      border: 4px solid white;
      box-shadow: var(--shadow-premium);
      overflow: hidden;
      position: relative;
      z-index: 2;
    }

    .hero-img-container img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: var(--transition-smooth);
    }

    .hero-img-container:hover img {
      transform: scale(1.03);
    }

    .hero-card-tag {
      position: absolute;
      bottom: 30px;
      left: -20px;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 14px 20px;
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-lg);
      border: 1px solid rgba(255, 255, 255, 0.6);
      display: flex;
      align-items: center;
      gap: 14px;
      z-index: 3;
      animation: float 6s ease-in-out infinite;
    }

    .hero-card-tag-icon {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: var(--accent-light);
      color: var(--accent);
      display: grid;
      place-items: center;
    }

    .hero-card-tag-icon svg {
      width: 18px;
      height: 18px;
    }

    .hero-card-tag-text strong {
      display: block;
      font-size: 0.9rem;
      color: var(--primary-dark);
    }

    .hero-card-tag-text span {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    /* Secciones generales */
    section { 
      padding: 104px 0; 
      border-bottom: 1px solid var(--border-light);
    }
    
    .section-header {
      max-width: 700px;
      margin-bottom: 56px;
    }

    .section-subtitle {
      color: var(--primary);
      text-transform: uppercase;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      margin-bottom: 12px;
      display: block;
    }

    .section-title { 
      font-family: 'Outfit', sans-serif;
      font-size: clamp(1.9rem, 3vw, 2.6rem); 
      color: var(--primary-dark);
      letter-spacing: -0.02em;
      line-height: 1.2;
    }

    /* Sección: Cuándo acudir a consulta */
    .symptom-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .symptom-card {
      background: var(--bg-card);
      border: 1px solid rgba(226, 232, 240, 0.8);
      border-radius: var(--radius-md);
      padding: 36px 28px;
      box-shadow: var(--shadow-sm);
      transition: var(--transition-smooth);
      position: relative;
      overflow: hidden;
    }

    .symptom-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background-color: var(--primary);
      transform: scaleX(0);
      transform-origin: left;
      transition: var(--transition-smooth);
    }

    .symptom-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
      border-color: rgba(2, 132, 199, 0.25);
    }

    .symptom-card:hover::before {
      transform: scaleX(1);
    }

    .symptom-icon {
      width: 52px;
      height: 52px;
      border-radius: var(--radius-sm);
      background: rgba(2, 132, 199, 0.05);
      color: var(--primary);
      display: grid;
      place-items: center;
      margin-bottom: 24px;
      transition: var(--transition-smooth);
    }

    .symptom-icon svg {
      width: 24px;
      height: 24px;
    }

    .symptom-card:hover .symptom-icon {
      background: var(--primary);
      color: white;
      transform: scale(1.05) rotate(5deg);
    }

    .symptom-card h3 {
      font-family: 'Outfit', sans-serif;
      font-size: 1.18rem;
      color: var(--primary-dark);
      margin-bottom: 12px;
    }

    .symptom-card p {
      font-size: 0.95rem;
      color: var(--text-muted);
    }

    /* Banner de Advertencia de Síntomas de Alarma */
    .alarm-banner {
      margin-top: 48px;
      background: #fffdf5;
      border: 1px solid #fdf3d7;
      border-left: 4px solid #d97706;
      padding: 24px;
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      gap: 20px;
      box-shadow: var(--shadow-sm);
    }
    
    .alarm-icon {
      color: #d97706;
      flex-shrink: 0;
      display: grid;
      place-items: center;
      width: 36px;
      height: 36px;
    }
    
    .alarm-icon svg {
      width: 28px;
      height: 28px;
    }
    
    .alarm-text {
      font-size: 0.98rem;
      color: #b45309;
      line-height: 1.55;
    }
    
    .alarm-text strong {
      color: #78350f;
    }

    /* Sección: Perfil del Doctor */
    .profile-grid {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 64px;
      align-items: center;
    }

    .profile-stats {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: #e2e8f0;
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: var(--radius-lg);
      padding: 48px 40px;
      box-shadow: var(--shadow-premium);
      position: relative;
      overflow: hidden;
    }

    .profile-stats::before {
      content: '';
      position: absolute;
      top: -20%;
      right: -20%;
      width: 60%;
      height: 60%;
      background: radial-gradient(circle, rgba(2, 132, 199, 0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .profile-stat-item {
      display: flex;
      align-items: center;
      gap: 20px;
      padding-bottom: 24px;
      margin-bottom: 24px;
      border-bottom: 1px solid #1e293b;
      position: relative;
      z-index: 2;
    }

    .profile-stat-item:last-child {
      padding-bottom: 0;
      margin-bottom: 0;
      border-bottom: none;
    }

    .profile-stat-circle {
      width: 56px;
      height: 56px;
      border-radius: 14px;
      background: rgba(56, 189, 248, 0.08);
      border: 1px solid rgba(56, 189, 248, 0.15);
      color: #38bdf8;
      display: grid;
      place-items: center;
      flex-shrink: 0;
      transition: var(--transition-smooth);
    }

    .profile-stat-circle svg {
      width: 24px;
      height: 24px;
    }

    .profile-stat-item:hover .profile-stat-circle {
      background: #38bdf8;
      color: #0f172a;
      transform: scale(1.08) rotate(-5deg);
    }

    .profile-stat-text strong {
      display: block;
      font-size: 1.15rem;
      color: #ffffff;
      font-family: 'Outfit', sans-serif;
      letter-spacing: -0.01em;
    }

    .profile-stat-text span {
      font-size: 0.9rem;
      color: #94a3b8;
    }

    .profile-text-content h3 {
      font-family: 'Outfit', sans-serif;
      font-size: 1.55rem;
      color: var(--primary-dark);
      margin-bottom: 20px;
      position: relative;
    }

    .profile-text-content p {
      color: var(--text-dark);
      margin-bottom: 20px;
      font-size: 1.05rem;
    }

    .profile-checklist {
      list-style: none;
      margin-top: 28px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .profile-checklist-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.95rem;
      color: var(--text-dark);
      font-weight: 500;
    }

    .profile-checklist-item svg {
      width: 16px;
      height: 16px;
      color: var(--accent);
      flex-shrink: 0;
    }

    /* Sección: Servicios y Procedimientos */
    .bg-light-sec {
      background-color: #f8fafc;
    }

    .services-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    .services-column-title {
      font-family: 'Outfit', sans-serif;
      font-size: 1.45rem;
      color: var(--primary-dark);
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .services-column-title svg {
      width: 24px;
      height: 24px;
      color: var(--primary);
    }

    .services-column {
      border-radius: var(--radius-lg);
      transition: var(--transition-smooth);
    }

    .services-column.featured {
      background: linear-gradient(180deg, rgba(2, 132, 199, 0.03) 0%, rgba(255, 255, 255, 0.8) 100%);
      border: 1px solid rgba(2, 132, 199, 0.25);
      border-radius: var(--radius-lg);
      padding: 40px 32px;
      box-shadow: var(--shadow-premium);
      position: relative;
    }

    .services-column.featured::before {
      content: 'Especialidad Principal';
      position: absolute;
      top: -12px;
      right: 32px;
      background: var(--primary);
      color: white;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 4px 14px;
      border-radius: 999px;
      box-shadow: 0 4px 12px rgba(2, 132, 199, 0.25);
    }

    .services-column.standard {
      padding: 40px 32px;
    }

    .service-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .service-card {
      background: white;
      border: 1px solid rgba(226, 232, 240, 0.8);
      border-radius: var(--radius-md);
      padding: 28px;
      box-shadow: var(--shadow-sm);
      transition: var(--transition-smooth);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .service-card:hover {
      transform: translateY(-3px) scale(1.005);
      box-shadow: var(--shadow-md);
      border-color: rgba(2, 132, 199, 0.2);
    }

    .service-card h4 {
      font-family: 'Outfit', sans-serif;
      font-size: 1.15rem;
      color: var(--primary-dark);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-weight: 700;
    }

    .service-card p {
      font-size: 0.92rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .service-tag {
      font-size: 0.7rem;
      padding: 3px 10px;
      background: rgba(16, 185, 129, 0.08);
      color: var(--accent-hover);
      border: 1px solid rgba(16, 185, 129, 0.15);
      border-radius: 999px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }

    /* Sección: Proceso de Atención */
    .process-timeline {
      position: relative;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 28px;
      margin-top: 48px;
    }

    /* Línea conectora del timeline */
    .process-timeline::before {
      content: '';
      position: absolute;
      top: 52px;
      left: 50px;
      right: 50px;
      height: 2px;
      background: linear-gradient(to right, var(--primary) 0%, var(--border) 50%, var(--primary) 100%);
      z-index: 1;
    }

    .process-step {
      position: relative;
      background: white;
      border: 1px solid rgba(226, 232, 240, 0.8);
      border-radius: var(--radius-md);
      padding: 32px 24px;
      box-shadow: var(--shadow-sm);
      z-index: 2;
      transition: var(--transition-smooth);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .process-step:hover {
      transform: translateY(-5px);
      border-color: var(--primary);
      box-shadow: var(--shadow-lg);
    }

    .process-number {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--primary);
      color: white;
      display: grid;
      place-items: center;
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 1.15rem;
      margin-bottom: 16px;
      box-shadow: 0 4px 10px rgba(2, 132, 199, 0.25);
      border: 3px solid white;
      transition: var(--transition-smooth);
    }
    
    .process-step:hover .process-number {
      background: var(--primary-hover);
      transform: scale(1.1);
    }

    .process-step h3 {
      font-family: 'Outfit', sans-serif;
      font-size: 1.18rem;
      color: var(--primary-dark);
      font-weight: 700;
    }

    .process-step p {
      font-size: 0.92rem;
      color: var(--text-muted);
      line-height: 1.55;
    }

    /* Sección: Preguntas Frecuentes (FAQ) - Minimalista */
    .faq-container {
      max-width: 820px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
    }

    .faq-item {
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(226, 232, 240, 0.8);
      border-radius: 0;
      overflow: hidden;
      box-shadow: none;
      transition: var(--transition-smooth);
    }

    .faq-item:hover {
      border-bottom-color: var(--primary);
    }

    .faq-header {
      width: 100%;
      padding: 28px 0;
      background: transparent;
      border: none;
      text-align: left;
      font-family: 'Outfit', sans-serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--primary-dark);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      transition: var(--transition-smooth);
    }

    .faq-header:hover {
      background: transparent;
      color: var(--primary);
    }

    .faq-icon {
      width: 20px;
      height: 20px;
      color: var(--primary);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      flex-shrink: 0;
    }

    .faq-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      background: transparent;
    }

    .faq-content-inner {
      padding: 0 0 28px 0;
      font-size: 1rem;
      color: var(--text-muted);
      border-top: none;
      padding-top: 8px;
      line-height: 1.6;
    }

    .faq-item.active {
      border-color: var(--primary);
    }

    .faq-item.active .faq-header {
      color: var(--primary);
    }

    .faq-item.active .faq-icon {
      transform: rotate(180deg);
    }

    .faq-item.active .faq-content {
      max-height: 250px; 
    }

    /* Sección: Ubicación y Contacto */
    .location-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: start;
    }

    .location-info {
      background: white;
      border: 1px solid rgba(226, 232, 240, 0.8);
      border-radius: var(--radius-lg);
      padding: 48px;
      box-shadow: var(--shadow-premium);
    }

    .contact-item {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 24px;
    }

    .contact-item:last-of-type {
      margin-bottom: 0;
    }

    .contact-icon {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--primary-light);
      color: var(--primary);
      display: grid;
      place-items: center;
      flex-shrink: 0;
    }

    .contact-icon svg {
      width: 20px;
      height: 20px;
    }

    .contact-detail h4 {
      font-family: 'Outfit', sans-serif;
      font-size: 1rem;
      color: var(--primary-dark);
      margin-bottom: 4px;
      font-weight: 700;
    }

    .contact-detail p, .contact-detail a {
      font-size: 0.95rem;
      color: var(--text-muted);
    }

    .contact-detail a:hover {
      color: var(--primary);
    }

    .location-actions {
      display: flex;
      gap: 14px;
      margin-top: 32px;
    }

    .map-container {
      height: 100%;
      min-height: 400px;
      border-radius: var(--radius-lg);
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: var(--shadow-lg);
    }

    .map-container iframe {
      width: 100%;
      height: 100%;
      min-height: 400px;
      display: block;
    }

    /* CTA Box */
    .cta-banner {
      background: linear-gradient(135deg, #0f172a 0%, #0284c7 100%);
      color: white;
      border-radius: var(--radius-lg);
      padding: 64px 56px;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow-premium);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .cta-banner::before {
      content: '';
      position: absolute;
      top: -20%;
      right: -10%;
      width: 320px;
      height: 320px;
      background: radial-gradient(circle, rgba(16, 185, 129, 0.15) 0%, transparent 70%);
      pointer-events: none;
    }

    .cta-banner::after {
      content: '';
      position: absolute;
      bottom: -30%;
      left: -10%;
      width: 380px;
      height: 380px;
      background: radial-gradient(circle, rgba(2, 132, 199, 0.2) 0%, transparent 70%);
      pointer-events: none;
    }

    .cta-content {
      max-width: 700px;
      position: relative;
      z-index: 2;
    }

    .cta-banner h2 {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(1.9rem, 3.5vw, 2.6rem);
      margin-bottom: 16px;
      line-height: 1.2;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .cta-banner p {
      font-size: 1.08rem;
      color: rgba(255, 255, 255, 0.85);
      margin-bottom: 32px;
    }

    .cta-actions {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    /* Footer */
    .footer {
      background-color: #0f172a;
      color: #94a3b8;
      padding: 64px 0 40px;
      border-top: none;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 48px;
      margin-bottom: 40px;
    }

    .footer-brand h3 {
      font-family: 'Outfit', sans-serif;
      color: white;
      font-size: 1.25rem;
      margin-bottom: 12px;
      font-weight: 700;
    }

    .footer-brand p {
      font-size: 0.92rem;
      line-height: 1.6;
      max-width: 340px;
    }

    .footer-links h4, .footer-contact h4 {
      font-family: 'Outfit', sans-serif;
      color: white;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 20px;
      font-weight: 700;
    }

    .footer-links ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .footer-links a {
      font-size: 0.92rem;
      font-weight: 500;
    }

    .footer-links a:hover {
      color: white;
    }

    .footer-contact-item {
      display: flex;
      gap: 12px;
      margin-bottom: 16px;
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .footer-contact-item svg {
      width: 18px;
      height: 18px;
      color: var(--primary);
      flex-shrink: 0;
      margin-top: 3px;
    }

    .footer-contact-item a:hover {
      color: white;
    }

    .footer-bottom {
      border-top: 1px solid #1e293b;
      padding-top: 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
      font-size: 0.85rem;
    }

    .footer-legal-notice {
      color: #64748b;
      max-width: 600px;
      line-height: 1.5;
    }

    /* Botón Flotante de WhatsApp */
    .whatsapp-float {
      position: fixed;
      bottom: 30px;
      right: 30px;
      z-index: 99;
      background-color: var(--accent);
      color: white;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      box-shadow: 0 8px 24px rgba(16, 185, 129, 0.3);
      cursor: pointer;
      transition: var(--transition-smooth);
    }

    .whatsapp-float::before {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: var(--accent);
      opacity: 0.3;
      z-index: -1;
      animation: pulse 2s infinite;
    }

    .whatsapp-float svg {
      width: 30px;
      height: 30px;
      fill: currentColor;
    }

    .whatsapp-float:hover {
      background-color: var(--accent-hover);
      transform: scale(1.08) translateY(-3px);
    }

    @keyframes pulse {
      0% { transform: scale(1); opacity: 0.5; }
      100% { transform: scale(1.6); opacity: 0; }
    }

    /* Barra Fija de Contacto Móvil (Solo visible en pantallas pequeñas) */
    .mobile-contact-bar {
      display: none;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 -10px 30px rgba(15, 23, 42, 0.06);
      z-index: 98;
      border-top: 1px solid rgba(226, 232, 240, 0.8);
    }

    .mobile-contact-bar a {
      display: inline-flex;
    }

    .mobile-contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding: 14px 20px 24px;
      gap: 14px;
    }

    .mobile-contact-grid .btn {
      width: 100%;
      border-radius: var(--radius-sm);
      padding: 14px 16px;
      font-size: 0.9rem;
      font-weight: 700;
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .hero-grid, .profile-grid, .location-grid { 
        grid-template-columns: 1fr; 
        gap: 48px;
      }
      
      .hero {
        padding: 80px 0 64px;
      }

      .hero-grid {
        text-align: center;
      }

      .hero-actions {
        justify-content: center;
      }

      .lead {
        margin-left: auto;
        margin-right: auto;
      }

      .hero-card {
        order: 1; 
      }

      .hero-card-tag {
        left: 20px;
      }

      .hero-img-container {
        max-width: 340px;
      }

      .symptom-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }

      .services-grid {
        grid-template-columns: 1fr;
        gap: 32px;
      }

      .services-column.featured, .services-column.standard {
        padding: 0;
        background: transparent;
        border: none;
        box-shadow: none;
      }

      .services-column.featured::before {
        display: none;
      }

      .process-timeline {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }

      .process-timeline::before {
        display: none;
      }

      .footer-grid {
        grid-template-columns: 1fr;
        gap: 32px;
      }
    }

    @media (max-width: 768px) {
      /* Estilos para el menú móvil */
      .menu-toggle {
        display: flex;
      }

      .menu {
        position: fixed;
        top: 80px;
        left: 0;
        width: 100%;
        height: calc(100vh - 80px);
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        flex-direction: column;
        justify-content: flex-start;
        align-items: stretch;
        padding: 40px 24px;
        gap: 20px;
        transform: translateX(100%);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 99;
        box-shadow: var(--shadow-lg);
        border-top: 1px solid var(--border-light);
      }

      .menu.open {
        transform: translateX(0);
      }

      .menu a {
        font-size: 1.15rem;
        padding: 12px 0;
        border-bottom: 1px solid var(--border-light);
        font-weight: 600;
      }

      .menu a::after {
        display: none;
      }

      .nav-actions {
        display: none; 
      }

      .symptom-grid, .process-timeline {
        grid-template-columns: 1fr;
      }

      .profile-checklist {
        grid-template-columns: 1fr;
      }

      /* Mostrar la barra inferior fija de contacto */
      .mobile-contact-bar {
        display: block;
      }

      body {
        padding-bottom: 100px; 
      }

      .footer {
        padding-bottom: 120px; 
      }

      .whatsapp-float {
        bottom: 100px; 
        right: 20px;
        width: 50px;
        height: 50px;
      }

      .whatsapp-float svg {
        width: 24px;
        height: 24px;
      }
      
      section {
        padding: 72px 0;
      }
      
      .cta-banner {
        padding: 48px 24px;
      }
      
      .location-info {
        padding: 32px 24px;
      }

      .location-actions {
        flex-direction: column;
      }
      
      .alarm-banner {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
        padding: 20px;
      }

      .hero {
        padding: 48px 0;
      }

      h1 {
        font-size: 1.85rem;
        margin-bottom: 16px;
      }

      h1 span {
        font-size: 1.05rem;
        margin-top: 8px;
      }

      .lead {
        margin-bottom: 24px;
        font-size: 1rem;
      }

      .hero-actions {
        margin-bottom: 28px;
      }
    }

    /* Accesibilidad: Foco visible */
    a:focus-visible, button:focus-visible {
      outline: 3px solid var(--primary);
      outline-offset: 2px;
    }

  </style>

